# Telegram Bot Credentials
TELEGRAM_TOKEN=your_telegram_bot_token_here

# Google Gemini API Credentials
GEMINI_API_KEY=your_gemini_api_key_here

# Access Control Whitelist (comma-separated list of integer User/Group IDs)
# Example: ALLOWED_USERS=12345678,98765432
ALLOWED_USERS=your_telegram_user_id_here

# Google Drive Integration
# The ID of the specific Google Drive folder where Excel budget/financial documents are stored
GOOGLE_DRIVE_FOLDER_ID=your_google_drive_folder_id_here
